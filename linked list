#include<iostream>
using namespace std;

class node{
    public:
    int data;
    node* next;

    node (int val){
        data = val;
        next = NULL;
    }
}

void printNodes(Node* head){
    Node* temp = head;
    while (temp != NULL){
        cout << temp -> data << " ";
        temp = temp -> next;
    }
    cout << endl;
}

int main (){
    Node *head = new Node(1);
    Node *second = new Node(2);
    Node *third= new Node(3);
    Node *fourth = new node(4);
    Node *fifth = new Node(5);

    head -> next = second;
    second -> next = third;
    third -> next = fourth;
    fourth -> next = fifth;

    printNodes(head);
    return 0;
}